[Unit]
Description=ANetBBS Selector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bbsselector
Group=bbsselector
WorkingDirectory=/opt/bbs-selector
ExecStart=/usr/bin/python3 /opt/bbs-selector/bbs_selector.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
